{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "pnpm install --frozen-lockfile=false && pnpm --filter @workspace/kopihub run build",
  "outputDirectory": "artifacts/kopihub/dist/public",
  "installCommand": "echo 'handled in buildCommand'",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "regions": ["sin1"]
}
